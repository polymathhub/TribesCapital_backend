{
  "name": "tribes-capital-backend",
  "version": "1.0.0",
  "description": "Tribes Capital - Unified Learning, Events & Community Platform",
  "author": "Engineering Team",
  "license": "MIT",
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs'); const path=require('path'); const target=path.resolve('dist'); if (fs.existsSync(target)) { try { fs.rmSync(target, { recursive: true, force: true }); } catch (error) { console.warn('Skipping dist cleanup:', error.message); } }\"",
    "build": "npm run build:frontend && npm run build:backend",
    "build:backend": "nest build",
    "build:frontend": "cd frontend && npm install && npm run build",
    "dev": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "dev:frontend": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "prisma db push && node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@getbrevo/brevo": "^6.0.2",
    "@nestjs/bull": "^10.0.1",
    "@nestjs/common": "^10.2.8",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.2.8",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@prisma/client": "^5.22.0",
    "aws-sdk": "^2.1500.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.11.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^8.5.1",
    "nodemailer": "^6.9.9",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^4.6.11",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.2.8",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "prisma": "^5.22.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
