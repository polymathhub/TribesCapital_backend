NODE_ENV=development
PORT=3000
APP_HOST=0.0.0.0
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://user:password@localhost:5432/tribes_capital_dev
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=tribes_capital

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=900
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=604800
REQUIRE_EMAIL_VERIFICATION=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

AWS_REGION=us-east-1
AWS_S3_BUCKET=tribes-capital-uploads
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_URL=

#############################
# SMTP / Mail configuration
#
# This file contains example values only. DO NOT commit real credentials.
# For Hostinger SMTP, typical settings are:
#   host: smtp.hostinger.com
#   port: 465
#   secure: true
#
# Use environment variables in your deployment/CI or a local, uncommitted .env file.
#############################

# SMTP-style variables (provider-agnostic)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@tribescapital.com

# Alternate MAIL_* names supported by the app (Hostinger example shown)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=noreply@tribes.capital
# MAIL_PASS should be set in your deployment environment (do not commit!)
MAIL_PASS=your-mail-password
MAIL_FROM=noreply@tribes.capital
# Set to true to disable email sending (useful for local dev)
MAIL_SKIP_TRANSPORT=false

# Production notes:
# - Provide real SMTP credentials via environment variables in your deployment platform (do NOT commit secrets).
# - Ensure `DATABASE_URL` points to a managed/Postgres instance reachable from your deployment.
# - In production `NODE_ENV=production` and the app requires a working database and SMTP credentials to send mail.
# - Remove MAIL_SKIP_TRANSPORT/SMTP_SKIP_TRANSPORT in production unless email sending is intentionally disabled.

LOG_LEVEL=debug
