# ============================================================================
# PRODUCTION-GRADE ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit actual .env files to version control

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=production
APP_NAME="Tribes Capital"
FRONTEND_URL=https://tribescapital.com
API_VERSION=v1
PORT=3000

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/tribes_capital
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=strong_password_here
DB_NAME=tribes_capital

# ============================================================================
# JWT AUTHENTICATION - 15 MIN ACCESS + 7 DAY REFRESH
# ============================================================================
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=generate-32-character-secret-key-for-access-tokens
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=generate-32-character-secret-key-for-refresh-tokens
JWT_REFRESH_EXPIRY=7d

# ============================================================================
# GOOGLE OAUTH 2.0
# ============================================================================
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=http://localhost:5173/auth/callback

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGIN=https://tribescapital.com,https://app.tribescapital.com

# ============================================================================
# EMAIL SERVICE (NODEMAILER)
# ============================================================================
# Set to 'false' to disable email sending (useful for development)
EMAIL_ENABLED=true

# Gmail SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# SendGrid Alternative (uncomment to use)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASSWORD=SG.xxx_token_here

# AWS SES Alternative (uncomment to use)
# EMAIL_HOST=email-smtp.region.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USER=ses-username
# EMAIL_PASSWORD=ses-password

EMAIL_FROM=noreply@tribescapital.com
EMAIL_FROM_NAME="Tribes Capital"

# ============================================================================
# REDIS (OPTIONAL - FOR CACHING & SESSIONS)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ============================================================================
# AWS (OPTIONAL - FOR FILE UPLOADS)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1

# ============================================================================
# SECURITY & RATE LIMITING
# ============================================================================
# Bcrypt password hashing rounds (12 is standard, higher = slower but more secure)
BCRYPT_ROUNDS=12

# Rate limiting window (milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# Session timeout (seconds)
SESSION_TIMEOUT=86400

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_GOOGLE_OAUTH=true
ENABLE_GITHUB_OAUTH=false
ENABLE_EMAIL_VERIFICATION=true
ENABLE_2FA=false
ENABLE_AUDIT_LOGGING=true

# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
DATADOG_API_KEY=

# ============================================================================
# DEVELOPMENT ONLY - NOT FOR PRODUCTION
# ============================================================================
# SWAGGER_ENABLED=true
# ALLOW_CREDENTIAL_IN_LOGS=false
